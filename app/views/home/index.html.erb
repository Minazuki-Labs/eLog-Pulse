<div class="flex min-h-screen bg-white">
  <aside class="w-64 flex-shrink-0 px-6 pt-10 border-r border-gray-50">
    <nav class="space-y-1">
      <p class="px-5 text-[13px] font-black text-slate-900 uppercase tracking-[0.2em] mb-6">
        Helpdesk
      </p>

      <% if current_user.school? %>
        <%= sidebar_link "Dashboard", root_path, "squares-2x2" %>
        <%= sidebar_link "My Tickets", tickets_path, "ticket" %>
        <%= sidebar_link "Create New Ticket", new_ticket_path, "plus-circle" %>
        <%= sidebar_link "Our Equipment", "#", "cube" %>
        <%= sidebar_link "Settings", edit_user_registration_path, "cog-6-tooth" %>

      <% elsif current_user.employee? || current_user.admin? %>
        <%= sidebar_link "Assigned to Me", tickets_path(scope: 'assigned'), "user-circle" %>
        <%= sidebar_link "Open Tickets", tickets_path(scope: 'open'), "inbox" %>
        <%= sidebar_link "Equipment Directory", "#", "clipboard-document-list" %>
        <%= sidebar_link "School Directory", "#", "building-office" %>

        <% if current_user.admin? %>
          <div class="pt-4 mt-4 border-t border-gray-100">
            <p class="px-5 text-[13px] font-black text-slate-900 uppercase tracking-[0.2em] mb-6">Admin Tools</p>
            <%= sidebar_link "Staff Management", "#", "users" %>
            <%= sidebar_link "Location Templates", "#", "rectangle-group" %>
          </div>
        <% end %>
      <% end %>
    </nav>
  </aside>

  <main class="flex-1 p-8 lg:p-12">
    <div class="max-w-5xl mx-auto"> <div class="flex justify-between items-center mb-10">
        <div>
          <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Support Tickets</h1>
          <p class="text-slate-400 mt-1 text-base">Manage and track your recent activity.</p>
        </div>
        
        <%= link_to new_ticket_path, class: "inline-flex items-center px-5 py-3 bg-blue-600 text-white text-sm font-bold rounded-xl shadow-md shadow-blue-100 hover:bg-blue-700 transition-all" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
          New Ticket
        <% end %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <% @tickets.each do |ticket| %>
          <%= link_to ticket, class: "group relative bg-white rounded-3xl p-7 border border-slate-200/60 shadow-sm hover:shadow-xl hover:shadow-blue-500/10 hover:-translate-y-1 transition-all duration-300 flex flex-col h-full overflow-hidden" do %>
            
            <div class="flex justify-between items-center mb-6">
              <div class="flex items-center gap-2">
                <span class="px-2.5 py-0.5 rounded-lg text-[11px] font-bold uppercase tracking-widest <%= status_color(ticket.status) %>">
                  <%= ticket.status %>
                </span>
              </div>
              
              <span class="text-[11px] font-semibold text-slate-400 tabular-nums">
                <%= ticket.created_at.strftime("%d %b %Y") %>
              </span>
            </div>

            <div class="mb-6">
              <h3 class="text-xl font-extrabold text-slate-800 group-hover:text-blue-600 transition-colors leading-tight mb-2">
                <%= ticket.equipment&.equipment_category&.name || "Equipment" %>
                <span class="block text-base font-normal text-slate-500 mt-1">
                  <%= ticket.issue_type&.name %>
                </span>
              </h3>

              <p class="text-slate-500 text-sm leading-relaxed line-clamp-3">
                <%= ticket.description %>
              </p>
            </div>

            <div class="mt-auto pt-5 border-t border-slate-50 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="h-8 w-8 rounded-full bg-slate-50 flex items-center justify-center text-slate-400">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                </div>
                <div class="flex flex-col">
                  <span class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Location</span>
                  <span class="text-xs font-bold text-slate-700 uppercase tracking-tight"><%= ticket.location&.name %></span>
                </div>
              </div>
              
              <div class="bg-blue-50 text-blue-600 p-2 rounded-xl group-hover:bg-blue-600 group-hover:text-white transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              </div>
            </div>

            <div class="absolute inset-x-0 bottom-0 h-1 bg-gradient-to-r from-blue-500 to-indigo-600 scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-500"></div>
          <% end %>
        <% end %>
      </div>
    </div>
  </main>
</div>