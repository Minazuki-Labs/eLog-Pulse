<div class="flex flex-col space-y-8">
  
  <div class="flex justify-between items-center">
    <div>
      <h1 class="text-3xl font-extrabold text-gray-900">Support Tickets</h1>
      <p class="text-gray-500 mt-1">Manage and track your recent activity.</p>
    </div>
    
    <%= link_to new_ticket_path, class: "flex items-center px-5 py-2.5 bg-blue-600 text-white font-semibold rounded-lg shadow-md hover:bg-blue-700 transition-all" do %>
      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="12 4v16m8-8H4"></path></svg>
      Create New Ticket
    <% end %>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Subject</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Date</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @tickets.each do |ticket| %>
          <tr class="hover:bg-gray-50 transition-colors">
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="text-sm font-medium text-gray-900">
                <%= ticket.issue_type&.name %>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="px-2.5 py-0.5 rounded-full text-xs font-medium <%= status_color(ticket.status) %>">
                <%= ticket.status.capitalize %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
              <%= ticket.created_at.strftime("%b %d, %Y") %>
            </td>
            <td class="px-6 py-4 text-right text-sm font-medium">
              <%= link_to "View", ticket, class: "text-blue-600 hover:text-blue-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    
    <% if @tickets.empty? %>
      <div class="text-center py-12">
        <p class="text-gray-400">No tickets found. Start by creating one!</p>
      </div>
    <% end %>
  </div>
</div>