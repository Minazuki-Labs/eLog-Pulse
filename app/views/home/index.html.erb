<div class="flex min-h-screen bg-white">
  <aside class="w-64 flex-shrink-0 px-6 pt-10 border-r border-gray-50">
    <nav class="space-y-1">
      <p class="px-4 text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-4">Support Menu</p>
      
      <%= link_to "#", class: "flex items-center px-4 py-3 text-sm font-bold text-blue-600 bg-blue-50 rounded-xl mb-2" do %>
        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
        Active Tickets
      <% end %>

      <%= link_to "#", class: "flex items-center px-4 py-3 text-sm font-semibold text-gray-400 hover:bg-gray-50 rounded-xl transition-all" do %>
        <svg class="w-5 h-5 mr-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        Completed
      <% end %>
    </nav>
  </aside>

  <main class="flex-1 p-8 lg:p-12">
    <div class="max-w-5xl mx-auto"> <div class="flex justify-between items-center mb-10">
        <div>
          <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Support Tickets</h1>
          <p class="text-slate-400 mt-1 text-base">Manage and track your recent activity.</p>
        </div>
        
        <%= link_to new_ticket_path, class: "inline-flex items-center px-5 py-3 bg-blue-600 text-white text-sm font-bold rounded-xl shadow-md shadow-blue-100 hover:bg-blue-700 transition-all" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
          New Ticket
        <% end %>
      </div>

      <div class="bg-white border border-gray-100 rounded-2xl shadow-sm overflow-hidden">
        <table class="min-w-full divide-y divide-gray-100">
          <thead class="bg-gray-50/50">
            <tr>
              <th class="px-6 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-widest">Subject</th>
              <th class="px-6 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-widest">Status</th>
              <th class="px-6 py-4 text-left text-xs font-bold text-gray-400 uppercase tracking-widest">Date</th>
              <th class="px-6 py-4"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @tickets.each do |ticket| %>
              <tr class="hover:bg-gray-50/30 transition-colors">
                <td class="px-6 py-5 text-sm font-bold text-slate-800"><%= ticket.issue_type&.name %></td>
                <td class="px-6 py-5">
                  <span class="px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider <%= status_color(ticket.status) %>">
                    <%= ticket.status %>
                  </span>
                </td>
                <td class="px-6 py-5 text-sm font-medium text-slate-400"><%= ticket.created_at.strftime("%b %d, %Y") %></td>
                <td class="px-6 py-5 text-right">
                  <%= link_to "View", ticket, class: "text-blue-600 font-bold text-sm hover:text-blue-800" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>