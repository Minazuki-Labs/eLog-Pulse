<%= link_to ticket, class: "group relative bg-white rounded-3xl p-7 border border-slate-200/60 shadow-sm hover:shadow-xl hover:shadow-blue-500/10 hover:-translate-y-1 transition-all duration-300 flex flex-col h-full overflow-hidden" do %>

  <div class="flex justify-between items-center mb-6">
    <div class="flex items-center gap-2">
      <span class="px-2.5 py-0.5 rounded-lg text-[11px] font-bold uppercase tracking-widest <%= status_color(ticket.status) %>">
        <%= ticket.status %>
      </span>
    </div>
    
    <span class="text-[11px] font-semibold text-slate-400 tabular-nums">
      <%= ticket.created_at.strftime("%d %b %Y") %>
    </span>
  </div>

  <div class="mb-6">
    <h3 class="text-xl font-extrabold text-slate-800 group-hover:text-blue-600 transition-colors leading-tight mb-2">
      <%= ticket.equipment&.equipment_category&.name || "Equipment" %>
      <span class="block text-base font-normal text-slate-500 mt-1">
        <%= ticket.issue_type&.name %>
      </span>
    </h3>

    <p class="text-slate-500 text-sm leading-relaxed line-clamp-3">
      <%= ticket.description %>
    </p>
  </div>

  <div class="mt-auto pt-5 border-t border-slate-50">
    <% if current_user.staff? %>
      <div class="flex items-center gap-3 mb-4">
        <div class="h-8 w-8 rounded-full bg-slate-50 flex items-center justify-center text-slate-400">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-7h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
        </div>
        <div class="flex flex-col">
          <span class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Requested By</span>
          <span class="text-xs font-bold text-slate-600 uppercase tracking-tight"><%= ticket.school&.name %></span>
        </div>
      </div>
    <% end %>

    <div class="flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="h-8 w-8 rounded-full bg-slate-50 flex items-center justify-center text-slate-400">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
        </div>
        <div class="flex flex-col">
          <span class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Location</span>
          <span class="text-xs font-bold text-slate-700 uppercase tracking-tight"><%= ticket.location&.name %></span>
        </div>
      </div>
      
      <div class="bg-blue-50 text-blue-600 p-2 rounded-xl group-hover:bg-blue-600 group-hover:text-white transition-all">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
      </div>
    </div>
  </div>

  <div class="absolute inset-x-0 bottom-0 h-1 bg-gradient-to-r from-blue-500 to-indigo-600 scale-x-0 group-hover:scale-x-100 transition-transform origin-left duration-500"></div>
<% end %>
