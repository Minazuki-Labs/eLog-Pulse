<div class="max-w-4xl mx-auto p-8">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-black text-slate-900"><%= @school.name %></h1>
      <p class="text-slate-500">All Registered Locations</p>
    </div>
    <%= link_to "Back to Profile", user_path(@school), class: "text-sm text-slate-600 hover:text-slate-900 font-medium" %>
  </div>

  <div class="bg-white p-6 rounded-2xl border border-slate-100 shadow-xl shadow-slate-200/60">
    <% if @locations.any? %>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <% @locations.each do |location| %>
          <div class="flex items-center justify-between bg-slate-50 p-4 rounded-xl border border-slate-200/60 shadow-sm">
            <div class="flex items-center gap-2.5">
              <span class="w-2 h-2 rounded-full bg-blue-500"></span>
              <span class="text-sm font-bold text-slate-700"><%= location.name %></span>
            </div>
            <span class="text-xs text-slate-400 font-medium">
              <%= location.equipment.count %> Equipment Items
            </span>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-slate-400 text-sm font-medium italic py-4">No locations registered for this school yet.</p>
    <% end %>
  </div>
</div>