<main class="flex-1 p-8 lg:p-12">
  <div class="max-w-5xl mx-auto">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10 pb-6 border-b border-slate-100">
      
      <div class="flex items-center gap-4">
        <%= link_to user_path(@school), class: "group p-2.5 bg-slate-100 hover:bg-slate-200 text-slate-600 hover:text-slate-900 rounded-xl transition-all", title: "Back to Profile" do %>
          <svg class="w-5 h-5 transform group-hover:-translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
        <% end %>
        <div>
          <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight"><%= @school.name %></h1>
          <p class="text-slate-400 mt-0.5 text-sm font-medium">All Registered Locations</p>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3 w-full md:w-auto">
        
        <div class="relative flex-1 sm:w-64">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-slate-400">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </span>
          <%= form_with url: user_locations_path(@school), method: :get, local: true, class: "w-full" do |f| %>
            <%= f.text_field :query, 
                             value: params[:query], 
                             placeholder: "Search locations...", 
                             class: "w-full pl-9 pr-4 py-2.5 bg-slate-50 border border-slate-200 focus:border-blue-500 focus:bg-white focus:ring-2 focus:ring-blue-500/20 rounded-xl text-sm font-medium text-slate-700 placeholder-slate-400 outline-none transition-all" %>
          <% end %>
        </div>

        <%= link_to new_user_location_path(@school), class: "inline-flex items-center justify-center px-4 py-2.5 bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold rounded-xl shadow-md shadow-blue-100 transition-all shrink-0" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
          </svg>
          Add Location
        <% end %>

      </div>
    </div>
    
    <% if @locations.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% @locations.each do |location| %>
          <div class="group relative bg-white rounded-2xl p-5 border border-slate-200/60 shadow-sm hover:shadow-xl hover:shadow-blue-500/5 hover:-translate-y-0.5 transition-all duration-300 flex items-center justify-between gap-6 overflow-hidden">
            
            <div class="flex items-center gap-4 flex-1 min-w-0">
              <div class="h-11 w-11 shrink-0 rounded-xl bg-blue-50 text-blue-600 font-bold text-xs flex items-center justify-center tracking-wider group-hover:bg-blue-600 group-hover:text-white transition-all duration-300">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
              </div>
              <div class="min-w-0">
                <h3 class="text-lg font-extrabold text-slate-800 group-hover:text-blue-600 transition-colors leading-snug truncate">
                  <%= location.name %>
                </h3>
              </div>
            </div>

            <div class="flex items-center gap-2.5 shrink-0">
              <div class="h-8 w-8 rounded-full bg-slate-50 flex items-center justify-center text-slate-400">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
                </svg>
              </div>
              <div class="flex flex-col">
                <span class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Equipment</span>
                <span class="text-xs font-bold text-slate-700 tracking-tight"><%= location.equipment.count %> Items</span>
              </div>
            </div>

            <div class="absolute inset-y-0 left-0 w-1 bg-gradient-to-b from-blue-500 to-indigo-600 scale-y-0 group-hover:scale-y-100 transition-transform origin-top duration-300"></div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-16 bg-slate-50 rounded-3xl border border-dashed border-slate-200">
        <p class="text-slate-400 font-medium">No locations registered for this school yet.</p>
      </div>
    <% end %>

  </div>
</main>