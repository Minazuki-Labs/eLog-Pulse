<div class="max-w-5xl mx-auto py-10 px-4">
  <div class="mb-6">
    <%= link_to user_path(@school), class: "group inline-flex items-center gap-2 text-slate-500 hover:text-blue-600 transition-colors" do %>
      <svg class="w-5 h-5 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
      <span class="font-semibold">Back to <%= @school.name %></span>
    <% end %>
  </div>

  <div class="bg-white rounded-[2.5rem] p-8 md:p-12 shadow-xl shadow-slate-200/40 border border-slate-100">
    <div class="mb-10">
      <h1 class="text-3xl font-black text-slate-900 tracking-tight">Add New Location</h1>
      <p class="text-slate-500 font-medium mt-1">Register a room and assign its initial technical infrastructure.</p>
    </div>

    <%= form_with(model: @location, data: { controller: "nested-form" }, class: "space-y-10") do |f| %>
      <%= hidden_field_tag :school_id, @school.id %>

      <% if @location.errors.any? %>
        <div class="bg-red-50 text-red-600 p-4 rounded-2xl mb-6 border border-red-100">
          <p class="font-black mb-2">Please correct the following:</p>
          <ul class="list-disc ml-5 space-y-1">
            <% @location.errors.each do |error| %>
              <li class="font-medium"><%= error.message %></li> 
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="w-full flex flex-col gap-2">
        <%= f.label :name, "Location / Room Name", class: "text-lg font-black text-slate-900 tracking-tight" %>
        <%= f.text_field :name, 
            placeholder: "e.g., Science Lab 2, Hall 4B", 
            required: true,
            class: "w-full rounded-2xl border-none bg-slate-50 focus:bg-white focus:ring-4 focus:ring-blue-500/10 transition-all p-4 text-slate-700 placeholder:text-slate-400" %>
      </div>

      <hr class="border-slate-100">

      <div class="space-y-4">
        <div>
          <h3 class="text-lg font-black text-slate-900 tracking-tight">Equipment Setup</h3>
          <p class="text-slate-500 font-medium mt-1">Assign specific components to this workspace.</p>
        </div>

        <div class="space-y-3" data-nested-form-target="container">
          <template data-nested-form-target="template">
            <%= f.fields_for :equipment, Equipment.new, child_index: "NEW_RECORD" do |e| %>
              <%= render "equipment_fields", f: e, equipment_categories: @equipment_categories %>
            <% end %>
          </template>

          <%= f.fields_for :equipment do |e| %>
            <%= render "equipment_fields", f: e, equipment_categories: @equipment_categories %>
          <% end %>
        </div>

        <button type="button" 
                data-action="click->nested-form#add" 
                class="inline-flex items-center gap-2 text-sm font-black text-blue-600 bg-blue-50 hover:bg-blue-100 px-4 py-2.5 rounded-xl transition-all border border-blue-100 mt-2 cursor-pointer">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
          </svg>
          Add Another Component
        </button>
      </div>

      <div class="flex justify-end pt-6 border-t border-slate-100">
        <%= f.submit "Register Location", 
            class: "bg-slate-900 hover:bg-blue-600 text-white px-8 py-4 rounded-2xl font-black text-base transition-all transform active:scale-95 shadow-xl shadow-blue-500/20 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>