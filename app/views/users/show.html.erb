<div class="max-w-5xl mx-auto py-10 px-4">
  
  <% # Top Navigation & Actions Bar %>
  <div class="flex items-center justify-between mb-6">
    <% back_path = current_user.school? ? tickets_path : schools_users_path %>
    <%= link_to back_path, class: "group flex items-center gap-2 text-slate-500 hover:text-blue-600 transition-colors" do %>
      <svg class="w-5 h-5 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
      <span class="font-semibold">Back to Directory</span>
    <% end %>

    <div class="flex items-center gap-2">
      <% if current_user.staff? %>
        <%= link_to edit_user_path(@school), 
            class: "p-2 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-all", 
            title: "Edit School Details" do %>
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
          </svg>
        <% end %>
      <% end %>
    </div>
  </div>

  <%= render "profile_detail", school: @school %>
</div>

<%= render "ticket_history", school: @school %>