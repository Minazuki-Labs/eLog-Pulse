<div class="max-w-5xl mx-auto px-4 pb-20" data-controller="ticket-toggle">
  <div class="mt-12 space-y-8">
    
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-4">
        <h3 id="ticket-history-heading" class="text-2xl font-black text-slate-900 tracking-tight">Ticket History Log</h3>
        <span class="px-3 py-1 rounded-full bg-blue-50 text-blue-600 text-xs font-black ring-1 ring-inset ring-blue-200/50">
          <%= @school.reported_tickets.count %>
        </span>
      </div>
    </div>

    <div class="space-y-6 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px before:h-full before:w-0.5 before:bg-slate-200">
      <% if @school.reported_tickets.any? %>
        <% @school.reported_tickets.order(status: :asc, created_at: :desc).each_with_index do |ticket, index| %>
          <% is_hidden = index >= 5 %>
          
          <div class="relative pl-10 group ticket-row <%= 'hidden' if is_hidden %>"
              data-ticket-toggle-target="ticket">
            
            <div class="absolute left-3.5 top-1/2 -translate-y-1/2 w-3.5 h-3.5 rounded-full border-2 border-white bg-slate-300 group-hover:bg-blue-600 group-hover:scale-110 transition-all z-10"></div>
            
            <%= link_to ticket_path(ticket), class: "block bg-white rounded-2xl p-5 border border-slate-200/60 shadow-sm hover:shadow-md hover:border-slate-300 transition-all duration-300" do %>
              <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                <div>
                  <div class="flex items-center gap-2 mb-1.5">
                    <span class="text-xs font-mono text-slate-400"><%= ticket.created_at.strftime("%d %b %Y") %></span>
                    <span class="w-1 h-1 rounded-full bg-slate-300"></span>
                    <span class="text-xs font-bold text-slate-400 tracking-tight flex items-center gap-1">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path></svg>
                      <%= ticket.location&.name %>
                    </span>
                  </div>
                  
                  <h4 class="text-base font-extrabold text-slate-800 group-hover:text-blue-600 transition-colors">
                    <%= ticket.equipment&.equipment_category&.name || "General Equipment" %> 
                    <span class="text-slate-400 font-medium">/</span> 
                    <span class="text-slate-600 font-semibold text-sm"><%= ticket.issue_type&.name %></span>
                  </h4>
                </div>

                <div class="flex items-center gap-3 self-start sm:self-center">
                  <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-wider <%= status_color(ticket.status) %> ring-1 ring-inset ring-black/5">
                    <%= ticket.status.humanize %>
                  </span>
                  
                  <div class="bg-slate-50 text-slate-400 p-1.5 rounded-lg group-hover:bg-blue-50 group-hover:text-blue-600 transition-all">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="relative pl-10 text-slate-400 italic text-sm">
          No maintenance or service tickets have been reported by this school yet.
        </div>
      <% end %>
    </div>

    <% if @school.reported_tickets.count > 5 %>
      <div class="flex justify-center pt-4">
        <button data-action="click->ticket-toggle#toggle" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-slate-200 bg-white hover:bg-slate-50 hover:border-slate-300 text-slate-600 font-bold text-sm shadow-sm hover:shadow active:scale-95 transition-all duration-200 cursor-pointer">
          <span data-ticket-toggle-target="text">Show More Tickets</span>
          <svg data-ticket-toggle-target="icon" class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>
      </div>
    <% end %>

  </div>
</div>