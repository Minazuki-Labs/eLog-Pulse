<%= link_to user_path(school), class: "group relative bg-white rounded-2xl p-5 border border-slate-200/60 shadow-sm hover:shadow-xl hover:shadow-blue-500/5 hover:-translate-y-0.5 transition-all duration-300 flex flex-col md:flex-row md:items-center justify-between gap-6 overflow-hidden" do %>

  <div class="flex items-center gap-4 flex-1 min-w-0">
    <div class="h-11 w-11 shrink-0 rounded-xl bg-blue-50 text-blue-600 font-bold text-xs flex items-center justify-center tracking-wider group-hover:bg-blue-600 group-hover:text-white transition-all duration-300">
      <%= school.initials %>
    </div>
    
    <div class="min-w-0">
      <h3 class="text-lg font-extrabold text-slate-800 group-hover:text-blue-600 transition-colors leading-snug truncate">
        <%= school.name %>
      </h3>
      <p class="text-slate-400 text-sm font-medium tracking-tight truncate mt-0.5">
        <%= school.email %>
      </p>
    </div>
  </div>

  <div class="flex items-center justify-between md:justify-end gap-8 shrink-0 border-t border-slate-50 pt-4 md:pt-0 md:border-none">
    
    <div class="flex items-center gap-2.5 w-24">
      <div class="h-8 w-8 rounded-full bg-slate-50 flex items-center justify-center text-slate-400">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
      </div>
      <div class="flex flex-col">
        <span class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Locations</span>
        <span class="text-xs font-bold text-slate-700 tracking-tight"><%= school.locations.count %></span>
      </div>
    </div>

    <div class="flex items-center gap-2.5 w-24">
      <div class="h-8 w-8 rounded-full bg-slate-50 flex items-center justify-center text-slate-400">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
        </svg>
      </div>
      <div class="flex flex-col">
        <span class="text-[10px] uppercase font-bold text-slate-400 tracking-wider">Tickets</span>
        <span class="text-xs font-bold text-slate-700 tracking-tight"><%= school.reported_tickets.count %></span>
      </div>
    </div>

    <div class="bg-blue-50 text-blue-600 p-2 rounded-xl group-hover:bg-blue-600 group-hover:text-white transition-all duration-300">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </div>
    
  </div>

  <div class="absolute inset-y-0 left-0 w-1 bg-gradient-to-b from-blue-500 to-indigo-600 scale-y-0 group-hover:scale-y-100 transition-transform origin-top duration-300"></div>
<% end %>