<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "E Log Pulse" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="E Log Pulse">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% unless devise_controller? %>
      <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-xl border-b border-slate-200/60 px-8 py-6 shadow-sm">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
          
          <div class="flex items-center space-x-12">
            <span class="text-2xl font-black text-slate-800 tracking-tighter">
              eLog <span class="text-blue-600">Pulse</span>
            </span>
          </div>

          <div class="flex items-center space-x-6">
            <div class="flex items-center space-x-4">
              <p class="text-sm font-bold text-slate-800 leading-tight">
                <%= current_user.name.presence || current_user.email.split('@').first.capitalize %>
              </p>
              
              <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-slate-50 to-slate-100 border border-slate-200 flex items-center justify-center text-slate-700 font-black shadow-inner">
                <%= (current_user.name.presence || current_user.email)[0].upcase %>
              </div>
            </div>
            
            <%= button_to "Sign Out", destroy_user_session_path, method: :delete, 
                class: "px-6 py-3 text-sm font-bold text-white bg-slate-900 hover:bg-blue-600 rounded-2xl shadow-lg shadow-slate-200 transition-all active:scale-95" %>
          </div>
        </div>
      </nav>
    <% end %>

    <div class="flex min-h-screen">
      <% unless devise_controller? %>
        <%= render "layouts/sidebar" %>
      <% end %>
      
      <main class="flex-1 w-full">
        <%= yield %>
      </main>
    </div>
  </body>
</html>
