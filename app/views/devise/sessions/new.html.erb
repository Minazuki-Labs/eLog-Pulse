<div class="fixed inset-0 w-full h-full flex items-center justify-center overflow-y-auto">
  
  <div class="absolute inset-0 z-0">
    <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80&w=2000" 
         class="w-full h-full object-cover" 
         alt="Office Background">
    <div class="absolute inset-0 bg-slate-900/40 backdrop-blur-md"></div>
  </div>

  <div class="relative z-10 w-full max-w-md m-4">
    <div class="bg-white/80 backdrop-blur-xl p-8 md:p-12 rounded-3xl shadow-2xl border border-white/20">
      <div class="mb-10 text-center">
        <h1 class="text-4xl font-black text-slate-800 tracking-tight mb-2">
          eLog Pulse
        </h1>
        <p class="text-slate-500 font-medium">Welcome back! Please sign in.</p>
      </div>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
        <div>
          <%= f.label :email, class: "block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1 ml-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", 
              class: "block w-full px-4 py-4 bg-white/50 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all outline-none", 
              placeholder: "email@address.com" %>
        </div>
        
        <div>
          <%= f.label :password, class: "block text-xs font-bold uppercase tracking-wider text-slate-700 mb-1 ml-1" %>
          <%= f.password_field :password, autocomplete: "current-password", 
              class: "block w-full px-4 py-4 bg-white/50 border border-slate-200 rounded-2xl focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all outline-none", 
              placeholder: "••••••••" %>
        </div>

        <div class="flex items-center justify-between py-2">
          <% if devise_mapping.rememberable? %>
            <div class="flex items-center">
              <%= f.check_box :remember_me, class: "w-4 h-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500" %>
              <%= f.label :remember_me, class: "ml-2 text-sm text-slate-600" %>
            </div>
          <% end %>
        </div>

        <div>
          <%= f.submit "Sign In", 
              class: "w-full py-4 px-6 bg-slate-900 hover:bg-black text-white font-bold rounded-2xl shadow-lg transform transition active:scale-95 cursor-pointer" %>
        </div>
      <% end %>

      <div class="mt-8 pt-6 border-t border-slate-200 text-center">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>