<div class="bg-white rounded-[2.5rem] p-8 md:p-12 shadow-xl shadow-slate-200/40 border border-slate-100">
  <%= form_with(model: @ticket, data: { 
      controller: "ticket-form",
      ticket_form_locations_url_value: locations_tickets_path,
      ticket_form_equipment_url_value: equipment_tickets_path,
      ticket_form_issue_types_url_value: issue_types_tickets_path
    }, class: "space-y-8") do |f| %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <% if !current_user.school? %>
        <div class="flex flex-col gap-2">
          <%= f.label :school_id, class: "text-sm font-black text-slate-700 ml-1" %>
          <%= f.collection_select :school_id, @schools, :id, :name, 
              { prompt: "" }, 
              { class: "w-full rounded-2xl border-none bg-slate-50 focus:bg-white focus:ring-4 focus:ring-blue-500/10 transition-all p-4 text-slate-700",
                placeholder: "Select School",
                data: { action: "change->ticket-form#updateLocations", ticket_form_target: "school" } } %>
        </div>
      <% end %>

      <div class="flex flex-col gap-2">
        <%= f.label :location_id, "Room / Location", class: "text-sm font-black text-slate-700 ml-1" %>
        <%= f.collection_select :location_id, @locations, :id, :name, 
            { prompt: "" }, 
            { class: "w-full rounded-2xl border-none bg-slate-50 focus:bg-white focus:ring-4 focus:ring-blue-500/10 transition-all p-4 text-slate-700",
              placeholder: "Select Location",
              data: { action: "change->ticket-form#updateEquipment", ticket_form_target: "location" } } %>
      </div>

      <div class="flex flex-col gap-2">
        <%= f.label :equipment_id, class: "text-sm font-black text-slate-700 ml-1" %>
        <%= f.collection_select :equipment_id, @equipment, :id, :display_name,
            { prompt: "" }, 
            { class: "w-full rounded-2xl border-none bg-slate-50 focus:bg-white focus:ring-4 focus:ring-blue-500/10 transition-all p-4 text-slate-700",
              placeholder: "Select Equipment",
              data: { action: "change->ticket-form#updateIssueTypes", ticket_form_target: "equipment" } } %>
      </div>

      <div class="flex flex-col gap-2">
        <%= f.label :issue_type_id, class: "text-sm font-black text-slate-700 ml-1" %>
        <%= f.collection_select :issue_type_id, @issue_types, :id, :name, 
            { prompt: "" }, 
            { class: "w-full rounded-2xl border-none bg-slate-50 focus:bg-white focus:ring-4 focus:ring-blue-500/10 transition-all p-4 text-slate-700",
              placeholder: "Select Issue Type",
              data: { ticket_form_target: "issueType" } } %>
      </div>

      <div class="flex flex-col gap-2">
        <%= f.label :priority, class: "text-sm font-black text-slate-700 ml-1" %>
        <%= f.select :priority, 
            Ticket.priorities.keys.map { |p| [p.humanize, p] }, 
            { prompt: "Select Priority" },
            { class: "w-full rounded-2xl border-none bg-slate-50 focus:bg-white focus:ring-4 focus:ring-blue-500/10 transition-all p-4 text-slate-700" } %>
      </div>
    </div>

    <div class="flex flex-col gap-2">
      <%= f.label :description, class: "text-sm font-black text-slate-700 ml-1" %>
      <%= f.text_area :description, 
          placeholder: "Describe the technical issue in detail...",
          class: "w-full rounded-[1.6rem] border-none bg-slate-50 focus:bg-white focus:ring-4 focus:ring-blue-500/10 transition-all p-6 text-slate-700 placeholder:text-slate-400 min-h-[150px] resize-none" %>
    </div>

    <div class="flex justify-end pt-4">
      <%= f.submit button_label, 
          class: "bg-slate-900 hover:bg-blue-600 text-white px-8 py-4 rounded-2xl font-black text-base transition-all transform active:scale-95 shadow-xl shadow-blue-500/20 cursor-pointer" %>
    </div>
  <% end %>
</div>