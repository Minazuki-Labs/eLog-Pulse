<div class="max-w-5xl mx-auto py-10 px-4">
  <div class="flex items-center justify-between mb-6">
    <% default_path = current_user.school? ? tickets_path : root_path %>
    <% back_path = session[:last_tickets_path] || request.referrer || default_path  %>

    <%= link_to back_path, class: "group flex items-center gap-2 text-slate-500 hover:text-blue-600 transition-colors" do %>
      <svg class="w-5 h-5 transform group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
      </svg>
      <span class="font-semibold">Back to Tickets</span>
    <% end %>

    <div class="flex items-center gap-2">
      <% if !@ticket.completed? %>
        <%= link_to edit_ticket_path(@ticket), 
            class: "p-2 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-all", 
            title: "Edit Ticket" do %>
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
          </svg>
        <% end %>
      <% end %>
      
      <% if current_user.admin? || (@ticket.employee_id.nil? && current_user == @ticket.school) %>
        <%= button_to ticket_path(@ticket), 
            method: :delete, 
            form: { data: { turbo_confirm: "Are you sure you want to permanently delete this ticket?" } },
            class: "p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-xl transition-all", 
            title: "Delete Ticket" do %>
          <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
          </svg>
        <% end %>
      <% end %>
    </div>
  </div>

  <%= render "details", ticket: @ticket %>
</div>

<div class="max-w-5xl mx-auto px-4 pb-20">
  <div class="mt-12 space-y-8">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-4">
        <h3 class="text-2xl font-black text-slate-900 tracking-tight">Activity Log</h3>
        <span class="px-3 py-1 rounded-full bg-blue-50 text-blue-600 text-xs font-black ring-1 ring-inset ring-blue-200/50">
          <%= @ticket.comments.count %>
        </span>
      </div>
    </div>

    <div class="bg-white rounded-[2rem] p-2 shadow-xl shadow-slate-200/40 border border-slate-100">
      <%= form_with(model: [ @ticket, Comment.new ], class: "relative") do |f| %>
        <%= f.text_area :body, 
            placeholder: "Type a technical note or status update...", 
            class: "w-full rounded-[1.6rem] border-none bg-slate-50 focus:bg-white focus:ring-4 focus:ring-blue-500/10 transition-all p-6 pb-16 text-slate-700 placeholder:text-slate-400 min-h-[120px] resize-none" 
        %>
        <div class="absolute bottom-4 right-4">
          <%= f.submit "Post", 
              class: "bg-slate-900 hover:bg-blue-600 text-white px-6 py-2.5 rounded-xl font-bold text-sm transition-all transform active:scale-95 flex items-center gap-2 shadow-lg shadow-blue-500/20" 
          %>
        </div>
      <% end %>
    </div>

    <div class="space-y-8 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px before:h-full before:w-0.5 before:bg-slate-200">
        <%= render partial: "comment", collection: @ticket.comments.order(created_at: :desc) %>
    </div>
  </div>
</div>
