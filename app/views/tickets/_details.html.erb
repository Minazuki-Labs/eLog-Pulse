<div class="bg-white rounded-[2rem] shadow-xl shadow-slate-200/60 border border-slate-100 overflow-hidden">
  <div class="flex flex-col md:flex-row">
    <div class="flex-1 p-8 md:p-12">
      <div class="mb-10">
        <div class="flex items-center">
          <% if current_user.staff? %>
            <%= form_with model: @ticket, class: "inline-block" do |f| %>
              <div class="relative group cursor-pointer">
                <span class="inline-flex items-center px-4 py-2.5 pr-10 rounded-full text-[11px] font-black uppercase tracking-widest <%= status_color(@ticket.status) %> ring-1 ring-inset ring-black/5 transition-all group-hover:ring-black/20 shadow-sm">
                  <%= @ticket.status.humanize %>
                </span>
                
                <div class="absolute right-3 top-1/2 -translate-y-1/2 text-current opacity-60 group-hover:opacity-100 transition-opacity">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
                  </svg>
                </div>

                <%= f.select :status, 
                    Ticket.statuses.keys.map { |s| [s.humanize, s] }, 
                    {}, 
                    { 
                      class: "absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10",
                      onchange: "this.form.requestSubmit()" 
                    } 
                %>
              </div>
            <% end %>
          <% else %>
            <span class="inline-flex items-center px-4 py-2.5 rounded-full text-[11px] font-black uppercase tracking-widest <%= status_color(@ticket.status) %> ring-1 ring-inset ring-black/5">
              <%= @ticket.status.humanize %>
            </span>
          <% end %>
        </div>

        <h1 class="text-4xl font-black text-slate-900 mt-4 tracking-tight leading-tight">
          <%= @ticket.equipment&.equipment_category&.name %>
        </h1>
        <p class="text-xl text-slate-500 font-medium mt-1"><%= @ticket.issue_type&.name %></p>
      </div>

      <div class="space-y-4">
        <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path></svg>
          Description
        </h4>
        <div class="prose prose-slate max-w-none text-slate-700 leading-relaxed bg-slate-50/50 p-6 rounded-2xl border border-slate-100">
          <%= simple_format @ticket.description %>
        </div>
      </div>
    </div>

    <div class="w-full md:w-80 bg-slate-50 border-l border-slate-100 p-8 md:p-10">
      <div class="space-y-8">
        <% if current_user.staff? %>
          <div>
            <label class="block text-[10px] uppercase font-black text-slate-400 tracking-wider mb-2">School</label>
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-lg bg-blue-100 flex items-center justify-center text-blue-600">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0z"></path></svg>
              </div>
              <p class="text-slate-900 font-bold leading-tight"><%= @ticket.school&.name %></p>
            </div>
          </div>
        <% end %>

        <div>
          <label class="block text-[10px] uppercase font-black text-slate-400 tracking-wider mb-2">Technician</label>
          <div class="flex items-center gap-3">
    
            <% if @ticket.completed? %> 
              <% if @ticket.employee.present? %>
                <div class="w-8 h-8 rounded-lg bg-slate-200 text-slate-500 flex items-center justify-center text-[10px] font-black">
                  <%= @ticket.employee.initials %>
                </div>
                <p class="text-slate-900 font-bold leading-tight"><%= @ticket.employee.name %></p>
              <% else %>
                <p class="text-slate-400 text-sm font-medium italic">Unassigned (Closed)</p>
              <% end %>

            <% elsif current_user.admin? %> <%# Admin View %>
              <%= form_with model: @ticket, class: "w-full" do |f| %>
                <div class="relative group">
                  <%= f.collection_select :employee_id, 
                      User.staff, :id, :name, 
                      { include_blank: "Unassigned" }, 
                      { 
                        class: "block w-full bg-white border border-slate-200 rounded-lg py-2 px-3 text-sm font-bold text-slate-900 focus:ring-2 focus:ring-blue-500 outline-none appearance-none",
                        onchange: "this.form.requestSubmit()" 
                      } 
                  %>
                  <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-slate-400">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path d="M19 9l-7 7-7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  </div>
                </div>
              <% end %>

            <% elsif current_user.employee? %> <%# Employee View %>
              <div class="flex flex-col gap-2">
                <div class="flex items-center gap-3">
                  <% if @ticket.employee.present? %> <%# If assigned %>
                    <div class="w-8 h-8 rounded-lg <%= @ticket.employee_id == current_user.id ? 'bg-blue-600 text-white' : 'bg-slate-200 text-slate-500' %> flex items-center justify-center text-[10px] font-black">
                      <%= @ticket.employee.initials %>
                    </div>
                    <div>
                      <p class="text-slate-900 font-bold text-sm leading-tight"><%= @ticket.employee.name %></p>

                      <% if @ticket.employee_id == current_user.id %> <%# If assigned to me %>
                        <%= button_to "Unassign Me", ticket_path(@ticket, ticket: { employee_id: nil }), 
                            method: :patch, 
                            class: "text-[10px] font-bold text-red-500 hover:text-red-700 transition-colors block mt-0.5" %>
                      <% end %>
                    </div>

                  <% else %> <%# If unassigned %>
                    <div class="w-8 h-8 rounded-lg border-2 border-dashed border-slate-200 flex items-center justify-center text-slate-300">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                    </div>
                    <%= button_to "Claim Ticket", ticket_path(@ticket, ticket: { employee_id: current_user.id }), 
                        method: :patch, 
                        class: "bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-xs font-black transition-all shadow-md shadow-blue-200" %>
                  <% end %>
                </div>
              </div>

            <% else %> <%# School View %>
              <% if @ticket.employee.present? %>
                <div class="w-8 h-8 rounded-lg bg-slate-900 flex items-center justify-center text-white text-[10px] font-black">
                  <%= @ticket.employee.initials %>
                </div>
                <p class="text-slate-900 font-bold leading-tight"><%= @ticket.employee.name %></p>
              <% else %>
                <div class="w-8 h-8 rounded-lg border-2 border-dashed border-slate-200 flex items-center justify-center text-slate-300">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                  </svg>
                </div>
                <p class="text-slate-400 text-sm font-medium italic">Unassigned</p>
              <% end %>
            <% end %>

          </div>
        </div>

        <div>
          <label class="block text-[10px] uppercase font-black text-slate-400 tracking-wider mb-2">Location</label>
          <p class="text-slate-700 font-semibold flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>
            <%= @ticket.location&.name %>
          </p>
        </div>

        <div>
          <label class="block text-[10px] uppercase font-black text-slate-400 tracking-wider mb-2">Priority Level</label>
          
          <%= form_with model: @ticket, class: "inline-block" do |f| %>
            <div class="relative group cursor-pointer">
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-md bg-white border border-slate-200 shadow-sm transition-all group-hover:border-slate-400 group-hover:pr-7">
                <span class="w-2 h-2 rounded-full <%= @ticket.priority == 'high' ? 'bg-red-500 animate-pulse' : (@ticket.priority == 'medium' ? 'bg-amber-500' : 'bg-green-500') %>"></span>
                <span class="text-sm font-bold text-slate-700 uppercase italic">
                  <%= @ticket.priority&.humanize || "Normal" %>
                </span>
              </div>

              <div class="absolute right-2 top-1/2 -translate-y-1/2 text-slate-400 opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
                </svg>
              </div>

              <%= f.select :priority, 
                  Ticket.priorities.keys.map { |p| [p.humanize, p] }, 
                  {}, 
                  { 
                    class: "absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10",
                    onchange: "this.form.requestSubmit()" 
                  } 
              %>
            </div>
          <% end %>
        </div>

        <div class="pt-6 border-t border-slate-200">
          <label class="block text-[10px] uppercase font-black text-slate-400 tracking-wider mb-2">Timeline</label>
          <div class="space-y-1">
            <p class="text-xs text-slate-500">Created <span class="text-slate-900 font-bold"><%= time_ago_in_words(@ticket.created_at) %> ago</span></p>
            <p class="text-[10px] font-mono text-slate-400"><%= @ticket.created_at.strftime("%d %b %Y, %H:%M") %></p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
